# ── Backend environment variables ──────────────────────────────────────────
# Copy this file to .env and fill in the values.
# cp .env.example .env

# ── Google AI ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ── Database ───────────────────────────────────────────────────────────────
# Local docker-compose default:
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/doc_intelligence

# Production (Render Postgres external URL — note: use asyncpg scheme):
# DATABASE_URL=postgresql+asyncpg://user:pass@host/dbname

# ── Redis ──────────────────────────────────────────────────────────────────
# Local docker-compose default:
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Production (Upstash Redis):
# REDIS_URL=rediss://default:token@host:6380
# CELERY_BROKER_URL=rediss://default:token@host:6380
# CELERY_RESULT_BACKEND=rediss://default:token@host:6380

# ── Authentication ─────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Local dev (default, no need to set):
# ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Production — set to your Vercel / custom frontend URL:
# ALLOWED_ORIGINS=https://your-app.vercel.app

# ── App settings ───────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
MAX_UPLOAD_SIZE_MB=20
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# ── Render ─────────────────────────────────────────────────────────────────
# Render injects PORT automatically. Leave this unset locally.
# PORT=10000